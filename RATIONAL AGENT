# Simple Rational Agent Example

# Environment
grid = [
    ['R', ' ', 'T'],
    ['X', 'X', ' '],
    [' ', ' ', ' ']
]

# Robot position
row = 0
col = 0

# Target position
target = (0, 2)

print("Robot Starts at:", (row, col))

# Rational Agent Logic
while (row, col) != target:

    # Move Right if possible
    if col < 2 and grid[row][col + 1] != 'X':
        col += 1
        print("Move Right ->", (row, col))

    # Otherwise Move Down
    elif row < 2 and grid[row + 1][col] != 'X':
        row += 1
        print("Move Down ->", (row, col))

    # If no move is possible
    else:
        print("No path exists! Robot is stuck.")
        break

# Check if target reached
if (row, col) == target:
    print("\nTarget Reached!")
